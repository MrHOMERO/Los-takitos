<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Intro Mundo 1</title>
    <style>
        body, html { 
            margin: 0; padding: 0; width: 100%; height: 100%; 
            background: black; overflow: hidden; 
        }
        
        #video-container { position: relative; width: 100vw; height: 100vh; }
        
        #video-intro { 
            width: 100%; height: 100%; object-fit: cover; 
            display: block;
        }

        .punto-mision {
            position: absolute;
            width: 60px; height: 60px;
            background: rgba(0, 255, 255, 0.2);
            border: 2px solid rgba(0, 255, 255, 0.8);
            border-radius: 50%;
            cursor: pointer;
            display: none; /* Se activa al terminar el video */
            animation: pulse 2s infinite;
            z-index: 10;
        }

        @keyframes pulse {
            0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(0, 255, 255, 0.4); }
            70% { transform: scale(1.1); box-shadow: 0 0 0 15px rgba(0, 255, 255, 0); }
            100% { transform: scale(1); }
        }
    </style>
</head>
<body>

    <div id="video-container">
        <video id="video-intro" playsinline autoplay muted>
            <source src="lv_0_20260704135348.mp4" type="video/mp4">
        </video>

        <button class="punto-mision" style="top: 40%; left: 35%;" onclick="irAMision('Sector A')"></button>
        <button class="punto-mision" style="top: 40%; left: 60%;" onclick="irAMision('Data Core B')"></button>
    </div>

    <script>
        const video = document.getElementById('video-intro');
        const botones = document.querySelectorAll('.punto-mision');

        // 1. Mostrar botones cuando el video termina
        video.onended = function() {
            botones.forEach(b => b.style.display = 'block');
        };

        // 2. Redirección
        function irAMision(destino) {
            localStorage.setItem('destinoMision', destino);
            window.location.href = 'mision.html';
        }

        // 3. Rescate por si el navegador bloquea el autoplay inicial
        document.body.addEventListener('click', () => {
            if (video.paused) {
                video.play();
            }
        }, { once: true });
    </script>
</body>
</html>
